{"transcript":"lʲitʲ","exists":true,"definitions":["Направлять струю жидкости куда-либо.","Выделять, источать (о свете, запахе и т.п.).","Изготовлять что-либо методом литья.","Идти (о сильном дожде)."],"examples":["Лить воду в стакан.","Солнце льёт свет.","Лить пули.","Дождь льёт как из ведра."],"lemma":"лить","lemmaPos":"verb","synonyms":["наливать","выливать","проливать"],"number":"singular","tense":"present","source":"лить"}