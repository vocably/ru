{"transcript":"ˈsutkʲɪ","exists":true,"definitions":["Единица времени, равная 24 часам, период от полуночи до полуночи или от восхода до восхода.","День и ночь вместе взятые."],"examples":["Прошло двое суток.","Сутки напролёт.","Работать круглые сутки."],"lemma":"сутки","lemmaPos":"noun","synonyms":["день"],"number":"plural","pluralForm":"сутки","source":"сутки"}